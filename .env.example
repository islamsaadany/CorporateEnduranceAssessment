# The Endurance Assessment — environment template.
# Copy to `.env.local` for local dev; set the same vars in Vercel for production.

# --- Required ---

# Neon PostgreSQL connection strings.
# On Vercel, both names are set automatically by the Neon integration.
# Locally, copy the connection details from the Neon dashboard.
#
#   POSTGRES_URL          → pooled (pgbouncer) — used at runtime
#   DATABASE_URL_UNPOOLED → direct connection  — used for migrations / db push
POSTGRES_URL="postgresql://USER:PASSWORD@HOST-pooler/DBNAME?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth session signing secret (any random 32+ char string)
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-me-with-32-byte-random-string"

# Public app URL — http://localhost:3000 locally, the Vercel URL in prod
NEXTAUTH_URL="http://localhost:3000"

# 32-byte AES-256 master key (base64). Encrypts admin-supplied AI provider API keys at rest.
# Generate with: `openssl rand -base64 32`
SETTINGS_ENCRYPTION_KEY="replace-me-with-base64-32-bytes"

# Header secret required by /api/cron/closure (Vercel Cron sends this once configured)
CRON_SECRET="replace-me-with-random-string"

# Super admin credentials.
#
# When BOTH SEED_SUPER_ADMIN_EMAIL and SEED_SUPER_ADMIN_PASSWORD are set in
# the environment, the matching login form submission authenticates as the
# super admin via env-var match (no DB password check). The DB row is
# created or repaired on demand. This is the recovery path for "I forgot
# the super admin password" — change the env var in Vercel and redeploy.
#
# Security trade-off: the password lives in plaintext in the Vercel env-var
# dashboard. Anyone with project edit access can read it. The dashboard
# surfaces a persistent banner whenever this is active so the trade-off
# stays visible. See src/lib/auth.ts for the matching login path.
#
# When unset, login falls back to the DB bcrypt hash for everyone.
# `npm run seed` (used at first DB setup) also reads these to create the
# initial super admin row.
SEED_SUPER_ADMIN_EMAIL="superadmin@forefront.example"
SEED_SUPER_ADMIN_PASSWORD="change-me-on-first-login"
SEED_SUPER_ADMIN_NAME="Super Admin"

# --- Optional bootstrap fallbacks ---
# Used when the active provider has no API key saved in the admin panel yet.
# A persistent banner directs the super admin to save the key in the panel.

GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
